#!/usr/bin/perl -w

use strict;
use warnings;

use JSON::PP qw();
use IO::File;
use Cwd qw();
use File::Spec qw();
use File::Basename qw();

use Fcntl ':mode';

use Getopt::Long qw(:config version bundling pass_through);

# Constants
use constant DEFAULT_CONFIG_FILE => q(.iospsync.json);

use constant ADD_MODE => 0;
use constant VERIFY_MODE => 1;

# Globals
our $VERSION = q(2.1.0);
our $HOME = (getpwuid($<))[7];
our @ALLOWED_EXTENSIONS = qw(png jpg heic mp4);

my ($help, $rlink, $config, $syncdir, $stdin);

GetOptions(
    'h|help' => \$help,
    'rlink|relative-link!' => \$rlink,
    'config=s' => \$config,
    'sync-dir=s' => \$syncdir,
    'stdin' => \$stdin
) or die 'Invalid usage; please run with --help';

if ($help) {
    usage();
    exit(0);
}

# Determine command mode
my $mode;
if (scalar(@ARGV) == 0) {
    die 'No command provided';
} elsif ($ARGV[0] eq 'add') {
    die 'File argument(s) required' if (scalar(@ARGV) == 1);

    $mode = ADD_MODE;
} elsif ($ARGV[0] eq 'verify') {
    die 'File argument(s) not supported for verify command' if (scalar(@ARGV) > 1);
    die '--stdin not supported for verify command' if ($stdin);

    $mode = VERIFY_MODE;
} else {
    die 'Unsupported command: ', $ARGV[0];
}

if (defined $config) {
    die 'Invalid --config' unless (-f $config);
} else {
    $config = File::Spec->catfile($HOME, DEFAULT_CONFIG_FILE);
}

if ($stdin) {
    die '--stdin specified, but file arguments detected' if (scalar(@ARGV) > 1);
}

# Main
my $sconf = SyncConfig->new($config);

if (defined $rlink) {
    print STDOUT 'Relative link set to ', $rlink, ' via command argument', "\n";
} else {
    $rlink = $sconf->isRelativeLink();
    print STDOUT 'Relative link set to ', $rlink, "\n";
}

$syncdir ||= $sconf->getSyncDirectory();
die 'No sync dir specified; please check ', $config, ' and/or the command line' unless (defined $syncdir);
die 'Invalid sync directory' unless (-d $syncdir);

print STDOUT 'Sync dir set to ', $syncdir, "\n";

# Command to run.
my $command;

if ($mode == VERIFY_MODE) {
    my $iter = VerifyFileIterator->new($syncdir);
    $command = VerifyCommand->new($iter);
} elsif ($mode == ADD_MODE) {
    my $iter;

    if ($stdin) {
        $iter = HandleFileIterator->new(\*STDIN);
    } else {
        shift(@ARGV);
        $iter = ARGVFileIterator->new(\@ARGV);
    }

    $command = AddCommand->new($iter, $syncdir, $rlink);
} else {
    die 'Fatal code error; operation mode ', $mode, ' not handled';
}

my ($result, $err) = $command->run();

if (scalar(@{$err})) {
    print STDOUT qq(\n--- ERROR SUMMARY ---\n);

    my $i = 0;
    foreach my $entry (@{$err}) {
        my $m = $entry->message();
        my $f = $entry->file();
        my $t = $entry->target();

        print STDOUT "\n";
        print STDOUT 'Error ', $i++, "\n";
        print STDOUT '- Message: ', (defined $m) ? $m : '_undef_', "\n";
        print STDOUT '-    File: ', (defined $f) ? $f : '_na_', "\n";
        print STDOUT '-  Target: ', (defined $t) ? $t : '_na_', "\n";
    }
}

exit(($result) ? 0 : 11);

sub usage {
    my $scriptname = File::Basename::basename($0);

    print STDOUT <<__USAGE_END__;

Usage: $scriptname <options> <commands> <...>

OPTIONS:

    h|help:
        Print this screen.

    rlink|relative-link|no-rlink|no-relative-link:
        Enable or disable if the created link should be relative or an
        absolute path.

    config <path to config>:
        Specify an alternate configuration file.

    sync-dir <path to directory>:
        The directory in which to create the symlink.

    stdin
        Read files from STDIN instead of the argument list.

COMMANDs:

    add:
        Add files provided.

    verify:
        This takes no argument; this validates symlinks.

__USAGE_END__

    return 1;
}

#
# Objects
#
package SyncConfig;

use strict;
use warnings;

use Carp qw();

sub new {
    my $pkg = shift;
    my ($file) = @_;

    my $obj = _load_config($file);
    return bless($obj, $pkg);
}

sub isRelativeLink {
    return $_[0]->{'rlink'};
}

sub getSyncDirectory {
    return $_[0]->{'sync_dir'};
}

sub _load_config {
    my ($file) = @_;

    my $fh = IO::File->new();
    $fh->open($file, 'r') or Carp::confess('Failed to open ', $file, ' for read');

    my @buffer;
    while (my $line = $fh->getline()) {
        push(@buffer, $line);
    }

    $fh->close() or Carp::cluck($!);

    my $json = join('', @buffer);

    my $ref = JSON::PP::decode_json($json);

    my $ret = {};

    # Validate as we can.
    if (defined $ref->{'useRelativeLink'}) {
        my $value = $ref->{'useRelativeLink'};
        Carp::croak('Invalid value for useRelativeLink in JSON configuration') unless (JSON::PP::is_bool($value));
        $ret->{'rlink'} = ($value) ? 1 : 0;
    } else {
        $ret->{'rlink'} = 0;
    }

    if (defined $ref->{'defaultSyncDir'}) {
        my $value = $ref->{'defaultSyncDir'};
        Carp::croak('Invalid value for defaultSyncDir in JSON configuration') if (ref($value));

        $value =~ s!^~/!qq(${main::HOME}/)!e;

        $ret->{'sync_dir'} = $value;
    }

    return $ret;
}

#---

package FileIterator;

use strict;
use warnings;

use Carp qw();

sub new {
    my $pkg = shift;
    return bless({}, $pkg);
}

sub next {
    Carp::confess('Not implemented');
}

sub close {
    return 1;
}

package HandleFileIterator;

use strict;
use warnings;

use parent -norequire, 'FileIterator';

sub new {
    my $pkg = shift;

    my $obj = $pkg->SUPER::new();
    $obj->{'fh'} = $_[0];

    return bless($obj, $pkg);
}

sub next {
    my ($self) = @_;

    my $ret = $self->{'fh'}->getline();

    if (defined $ret) {
        chomp($ret);
    }

    return $ret;
}

sub close {
    my ($self) = @_;
    $self->SUPER::close();
    return $self->{'fh'}->close();
}

package ARGVFileIterator;

use strict;
use warnings;

use parent -norequire, 'FileIterator';

sub new {
    my $pkg = shift;

    my $obj = $pkg->SUPER::new();

    my $argv = $_[0];

    $obj->{'i'} = 0;
    $obj->{'argc'} = scalar(@{$argv});
    $obj->{'argv'} = $argv;

    return bless($obj, $pkg);
}

sub next {
    my ($self) = @_;

    my $current = $self->{'i'}++;
    return ($current < $self->{'argc'}) ? $self->{'argv'}->[$current] : undef;
}

package VerifyFileIterator;

use strict;
use warnings;

use Carp qw();

use parent -norequire, 'FileIterator';

sub new {
    my $pkg = shift;
    my $obj = $pkg->SUPER::new();
    my $dir = $_[0];

    opendir(my $dh, $dir) or Carp::confess('Failed to open directory ', $dir, ' for read: ', $!);

    $obj->{'dh'} = $dh;
    $obj->{'dir'} = $dir;

    return bless($obj, $pkg);
}

sub next {
    my ($self) = @_;

    my $dh = $self->{'dh'};
    return undef unless ($dh);

    while (my $entry = readdir($dh)) {
        next if ($entry =~ /^\.+$/o);

        my $fullPath = File::Spec->catfile($self->{'dir'}, $entry);
        return $fullPath;
    }

    # If we made it here, the dir contents are exhausted.
    $self->_close();
    return undef;
}

sub _close {
    my ($self) = @_;

    closedir($self->{'dh'});
    $self->{'dh'} = undef;

    return 1;
}

sub DESTROY {
    my $self = shift;

    if ($self->{'dh'}) {
        $self->_close();
    }

    return 1;
}

# struct error;
package CommandError;

use strict;
use warnings;

sub new {
    my $pkg = shift;
    my ($msg, $file, $target) = @_;
    return bless([$msg, $file, $target], $pkg);
}

sub file {
    return $_[0]->[1];
}

sub message {
    return $_[0]->[0];
}

sub target {
    return $_[0]->[2];
}

package Command;

use strict;
use warnings;

use Carp qw();
use Scalar::Util qw();

sub new {
    my $pkg = shift;
    my ($iter) = @_;

    Carp::confess('Iterator required') unless (defined $iter);
    Carp::confess('Invalid iterator') unless (defined Scalar::Util::blessed($iter) && $iter->isa('FileIterator'));

    return bless({
        'iter' => $iter
    }, $pkg);
}

sub run {
    Carp::confess('Not implemented');
}

sub _iterator {
    return $_[0]->{'iter'};
}

package AddCommand;

use strict;
use warnings;

use Carp qw();

use parent -norequire, 'Command';

sub new {
    my $pkg = shift;
    my ($iter, $sdir, $rlink) = @_;

    my $obj = $pkg->SUPER::new($iter);
    $obj->{'rlink'} = ($rlink) ? 1 : 0;
    $obj->{'sdir'} = $sdir;
    return bless($obj, $pkg);
}

sub run {
    my ($self) = @_;

    my $iter = $self->_iterator();
    my $rlink = $self->{'rlink'};
    my $sdir = $self->{'sdir'};

    my @errors;
    my @toLink;
    while (my $file = $iter->next()) {
        if (-e $file) {
            my $full = Cwd::abs_path($file);
            if (! defined $full) {
                push(@errors, CommandError->new('Unable to determine absolute path', $file));
                next;
            } elsif (! -f $full) {
                push(@errors, CommandError->new('Not a file', $file));
                next;
            } elsif (! _verify_file_extension($full)) {
                push(@errors, CommandError->new('Unsupported file extension', $file));
                next;
            }

            push(@toLink, $full);
        } else {
            push(@errors, CommandError->new('File not found', $file));
        }
    }

    return (0, \@errors) if (scalar(@errors) != 0 || scalar(@toLink) == 0);

    # Determine link settings
    foreach my $x (@toLink) {
        my $create = File::Spec->catfile($sdir, File::Basename::basename($x));

        if (-l $create) {
            my $tmp = Cwd::abs_path($create);

            if (! defined $tmp) {
                push(@errors, CommandError->new($!, $x, $create));
            } elsif (-e $tmp) {
                # We already know X exists from above checks
                my ($devX, $inoX) = (stat($x))[0, 1];
                my ($devT, $inoT) = (stat($tmp))[0, 1];

                if ($devX != $devT || $inoX != $inoT) {
                    push(@errors, CommandError->new('Symlink already exists', $x, $create));
                }
            } else {
                push(@errors, CommandError->new('Broken symlink already exists', $x, $create));
            }

            next;
        } elsif (-e $create) {
            push(@errors, CommandError->new('File exists where symlink required', $x, $create));
            next;
        }

        my $link = ($rlink) ? File::Spec->abs2rel($x, $sdir) : $x;

        print STDOUT 'Creating symlink: ', $create, ' -> ', $link, "\n";

        my $check = symlink($link, $create);
        if (!$check) {
            print STDOUT '[ERROR] Symlink creation failed!', "\n";
            push(@errors, CommandError->new('Symlink creation failed', $x, $create));
            next;
        }

        $check = _set_link_time($x, $create);

        if (!$check) {
            print STDOUT '[ERROR] Failed to set file times for symlink!', "\n";
            push(@errors, CommandError->new('Symlink time modification failed', $x, $create));
        }
    }

    my $ret = (scalar(@errors) == 0) ? 1 : 0;
    return ($ret, \@errors);
}

sub _verify_file_extension {
    if ($_[0] =~ /\.([a-zA-Z0-9]+)$/o) {
        my $ext = lc($1);
        my $found = grep { $ext eq $_ } @main::ALLOWED_EXTENSIONS;
        return ($found > 0) ? 1 : 0;
    } # else failure

    return 0;
}

sub _set_link_time {
    my ($source, $link) = @_;

    my ($atime, $mtime) = (stat($source))[8 ,9];

    my $pid = undef;
    if ($pid = fork()) {
        waitpid($pid, 0);
        my $rc = $? >> 8;
        return $rc == 0;
    } elsif (defined $pid) {
        my @cmd = (
            '/usr/bin/touch',
            '-h',
            '-r', $source,
            $link
        );

        exec(@cmd);
        exit(127);
    } else {
        Carp::confess('Failure to fork: ', $!);
    }

    return 0;
}

package VerifyCommand;

use strict;
use warnings;

use parent -norequire, 'Command';

sub new {
    my $pkg = shift;
    my ($iter) = @_;
    my $obj = $pkg->SUPER::new($iter);
    return bless($obj, $pkg);
}

sub run {
    my ($self) = @_;

    my $iter = $self->_iterator();

    my @errors;
    while (my $file = $iter->next()) {
        # Due to how this works, we know the file exists.
        if (-l $file) {
            my $resolved = Cwd::abs_path($file);
            if (! defined $resolved) {
                push(@errors, CommandError->new($!, $file));
            } elsif (-e $resolved) {
                my $mode = (stat($resolved))[2];
                my $type = $mode & main::S_IFMT;

                if (! main::S_ISREG($type)) {
                    push(@errors, CommandError->new('Invalid target file type', $file, $resolved));
                }
            } else {
                push(@errors, CommandError->new('Broken symlink', $file, $resolved));
            }
        }

        #else this is something we don't need to validate.
    }

    my $ret = (scalar(@errors) == 0) ? 1 : 0;
    return ($ret, \@errors);
}
